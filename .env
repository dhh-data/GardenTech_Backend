# =========================================================
# KONFIGURASI DATABASE (MySQL via XAMPP/Laragon)
# Sesuaikan dengan setting MySQL di komputer kamu.
# Default XAMPP: host=localhost, port=3306, user=root, password kosong.
# =========================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gardentech_db
DB_USER=root
DB_PASSWORD=

# =========================================================
# JWT (untuk token login)
# Ganti SECRET_KEY ini dengan string acak sendiri saat deploy asli.
# =========================================================
JWT_SECRET_KEY=ganti-dengan-kunci-rahasia-kamu-sendiri-ya
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# =========================================================
# MQTT (HiveMQ) - belum dipakai aktif, disiapkan untuk nanti
# =========================================================
MQTT_BROKER=8e31108a5e4a465d9fa600b9a2ee527b.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=GardenTech_Server
MQTT_PASSWORD=Server_FARM2575
MQTT_TOPIC_SENSOR=gardenkit/+/sensor
MQTT_TOPIC_CONTROL=gardenkit/+/control

# =========================================================
# CORS - alamat frontend yang boleh akses API ini
# Sesuaikan kalau frontend dibuka dari live server / port lain
# =========================================================
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5500,http://127.0.0.1:5500
